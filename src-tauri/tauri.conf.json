{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "LLM Knowledge Base",
  "version": "0.1.0",
  "identifier": "com.llm-knowledge-base.app",
  "build": {
    "frontendDist": "../demo/web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../demo/web && npm run dev",
    "beforeBuildCommand": "cd demo/web && npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "LLM 知识库",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' http://localhost:* https://*.openai.com https://*.deepseek.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["prompts/**/*.md"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
